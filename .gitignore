# =====================================================================
# Si-Chip .gitignore
# Adapted from the canonical DevolaFlow ignore policy (v8.3.0 Q-5).
# =====================================================================

# --- Python --------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/

# --- Testing / coverage -------------------------------------------------
.pytest_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
coverage.json
*.cover

# --- Type checkers / linters -------------------------------------------
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/

# --- Node (for any frontend / demo / docs) ------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Editor / IDE -------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.iml

# --- OS noise -----------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Secrets / env ------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# --- Logs ---------------------------------------------------------------
*.log

# --- DevolaFlow runtime state (created at execution time) --------------
.workflow-state/
.workflow/

# --- GitHub Pages / Jekyll build outputs ----------------------------------
docs/_site/
docs/.jekyll-cache/
docs/.jekyll-metadata

# --- Lockfiles for tools we do NOT vendor (kept out of v0 release) -------
poetry.lock
uv.lock
Pipfile.lock

# --- Local agent/runtime state -----------------------------------------
# Keep `.local/` available on each machine, but do not track it in git.
.local/
